# MongoDB Atlas — use DATABASE_URL (SRV) or DATABASE_URL_STANDARD (non-SRV from Atlas "Connect") if SRV/DNS fails
# Example SRV: mongodb+srv://USER:PASS@cluster.mongodb.net/vcs?retryWrites=true&w=majority
DATABASE_URL="mongodb+srv://USER:PASS@cluster.mongodb.net/vcs?retryWrites=true&w=majority"
# Optional: paste "standard connection string" from Atlas when you see querySrv / DNS errors (no mongodb+srv)
# DATABASE_URL_STANDARD="mongodb://USER:PASS@host1:27017,host2:27017/vcs?replicaSet=...&ssl=true&authSource=admin"
# Optional: Google + Cloudflare DNS for Node SRV lookups (ISP/router fixes)
MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
# Database name (default vcs). Must match path in URI if you rely on URI for db name.
MONGODB_DB_NAME=vcs

# SMTP Email (Gmail App Password)
# 1. Enable 2FA on your Google account
# 2. Go to myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Admin notifications (overrides hardcoded admin email if set)
ADMIN_EMAIL=admin@virtualcustomersolution.com

# Admin Dashboard auth — required to access /admin
ADMIN_USER=admin
ADMIN_PASS=change-me-to-a-strong-password
# Optional: random string used to sign admin session cookies.
# Falls back to ADMIN_PASS if unset.
ADMIN_SESSION_SECRET=replace-with-32-char-random-string

# Alpha CRM Webhook — leads/tickets forwarded here after submission (non-blocking)
# This is the BASE URL only — the helper appends /api/webhook/leads or /api/webhook/tickets.
CRM_WEBHOOK_URL=https://fu-corp-crm.vercel.app
CRM_WEBHOOK_SECRET=replace-with-actual-secret-from-crm-vercel-env
# Shared secret for HMAC-SHA256 request signing (X-Webhook-Signature header).
LEAD_WEBHOOK_SECRET=replace-with-hmac-signing-secret

# Rate Limiting (optional — falls back to in-memory)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Google (optional)
# GOOGLE_VERIFICATION=your-verification-code

# AdSense (optional)
# NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXX
