# =============================================================================
# Virtual Customer Solutions — PRODUCTION environment variables
# Host (Vercel, Railway, VPS, etc.) ke dashboard par yeh keys set karein.
# Asli passwords / URLs kabhi Git mein commit NA karein — sirf yeh example file.
# =============================================================================

# --- MongoDB (required for blogs, services, leads in DB) ----------------------
# Atlas: prefer standard connection string if SRV/DNS issues (Windows/network).
DATABASE_URL=
# Optional: non-SRV URI (overrides DATABASE_URL when both set — see lib/mongodb.ts)
DATABASE_URL_STANDARD=
# Optional: database name if not in URI path
MONGODB_DB_NAME=vcs
# Optional: comma-separated DNS servers if querySrv fails, e.g. 8.8.8.8,1.1.1.1
MONGO_DNS_SERVERS=

# --- Admin panel (/admin/login cookie session) -------------------------------
# REQUIRED in production: strong unique values (do NOT reuse dev passwords).
ADMIN_USER=
ADMIN_PASS=
# REQUIRED: long random string (e.g. openssl rand -hex 32). Used to sign session cookie.
ADMIN_SESSION_SECRET=

# --- NextAuth (only if you use /api/auth/[...nextauth] credentials flow) ----
NEXTAUTH_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Email (optional — contact form notifications if SMTP set) --------------
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# --- Rate limiting (recommended production) ----------------------------------
# Without these, app falls back to in-memory limiter (not ideal on serverless).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- CRM / lead webhook (optional) --------------------------------------------
CRM_WEBHOOK_URL=
LEAD_WEBHOOK_SECRET=

# --- Runtime (usually set by host — do not set manually unless you know) -----
# NODE_ENV=production
